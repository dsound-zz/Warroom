{
  "name": "@warroom/backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "ingester:hn": "tsx src/scripts/runIngester.ts hn",
    "ingester:techcrunch": "tsx src/scripts/runIngester.ts techcrunch",
    "ingester:engblogs": "tsx src/scripts/runIngester.ts engBlogs",
    "import:dna": "tsx src/scripts/importDna.ts",
    "import:applications": "tsx src/scripts/importApplications.ts",
    "import:tracker": "tsx src/scripts/importTracker.ts"
  },
  "dependencies": {
    "@warroom/shared": "workspace:*",
    "hono": "^4.4.13",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.2.2",
    "drizzle-orm": "^0.32.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8",
    "pino": "^9.3.2",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.23.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "@types/node": "^22.4.0",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^11.2.2"
  }
}
