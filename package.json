{
  "name": "warroom",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:backend": "pnpm --filter @warroom/backend dev",
    "dev:frontend": "pnpm --filter @warroom/frontend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @warroom/backend db:generate",
    "db:migrate": "pnpm --filter @warroom/backend db:migrate",
    "ingester:hn": "pnpm --filter @warroom/backend ingester:hn",
    "ingester:techcrunch": "pnpm --filter @warroom/backend ingester:techcrunch",
    "ingester:engblogs": "pnpm --filter @warroom/backend ingester:engBlogs",
    "import:dna": "pnpm --filter @warroom/backend import:dna",
    "import:applications": "pnpm --filter @warroom/backend import:applications"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
